<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="catdb"
        Arguments=""
        InstallLocation="C:\Program Files\catdb\catdb">
    </Installer>
    <PackageInformation
        PackageName="catdb"
        PackageDisplayName="catdb"
        PublisherName="CN=catdb"
        PublisherDisplayName="catdb"
        Version="0.1.0.0"
        PackageDescription="Cross-platform database management tool">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.catdb.app"
                Description="Cross-platform database management tool"
                DisplayName="catdb"
                ExecutableName="catdb"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>catdb</DisplayName>
            <PublisherDisplayName>catdb</PublisherDisplayName>
            <Description>Cross-platform database management tool</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="catdb.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
