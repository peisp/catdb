# Auto-detect text files; on commit, convert CRLF to LF
* text=auto

# Source code: always LF (cross-platform consistency)
*.go     text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.js     text eol=lf
*.vue    text eol=lf
*.css    text eol=lf
*.html   text eol=lf
*.json   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.md     text eol=lf

# Go module files
go.mod   text eol=lf
go.sum   text eol=lf

# Shell scripts
*.sh     text eol=lf

# Windows batch
*.bat    text eol=crlf
*.cmd    text eol=crlf

# Binary files (do not touch)
*.png    binary
*.jpg    binary
*.jpeg   binary
*.ico    binary
*.icns   binary
*.woff2  binary
